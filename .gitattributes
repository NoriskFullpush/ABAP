# Auto detect text files and perform LF normalization
# --- 기본 텍스트 처리 설정 ---
* text=auto

# --- ABAP 파일 설정 ---
*.abap text eol=lf diff=abap linguist-language=ABAP

# --- 문서 파일 ---
*.md text eol=lf diff=markdown
*.txt text eol=lf

# --- 이미지 파일 (이진 파일은 diff 무시) ---
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary

# --- Excel 파일 / 기타 이진 파일 ---
*.xlsx binary
*.xls binary
*.ods binary

git add .gitattributes
git commit -m "Add ABAP-specific .gitattributes"
git push

# ~/.gitconfig or .git/config
[diff "abap"]
    xfuncname = ^(FORM|CLASS|METHOD|FUNCTION).*$

