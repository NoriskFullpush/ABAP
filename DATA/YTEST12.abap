REPORT YTEST12 NO STANDARD PAGE HEADING.

TYPES: BEGIN OF ST_SPFLI,
  CARRID  TYPE SPFLI-CARRID,
  CONNID  TYPE SPFLI-CONNID,
  COUNTRYFR TYPE SPFLI-COUNTRYFR,
  CITYFROM  TYPE SPFLI-CITYFROM,
  COUNTRYTO TYPE SPFLI-COUNTRYTO,
  END OF ST_SPFLI.

DATA: GT_SPFLI TYPE TABLE OF ST_SPFLI WITH HEADER LINE.

SELECT * INTO CORRESPONDING FIELDS OF TABLE GT_SPFLI
FROM GT_SPFLI.

WRITE / SY-ULINE+0(50).
LOOP AT GT_SPFLI.
  WRITE: / SY-VLINE, GT_SPFLI-CARRID,
      SY-VLINE, GT_SPFLI-CONNID,
      SY-VLINE, GT_SPFLI-COUNTRYFR,
      SY-VLINE, GT_SPFLI-CITYFROM,
      SY-VLINE, GT_SPFLI-COUNTRYTO,
      50 SY-VLINE.
  WRITE / SY-ULINE+0(50).
  ENDLOOP.
